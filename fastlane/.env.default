# iOS: App Store Connect API key is used for auth (no Apple ID needed)
# Key: ~/.appstoreconnect/AuthKey_FC74HC6DF7.p8 (shared with checkin app)

# Android: Path to Google Play Store service account JSON key
# NOTE: The Veltric key (~/.fastlane/play-store-key.json) won't work here —
# you need to add this app to Google Play Console and grant API access to a
# service account, or create a new one at:
# https://play.google.com/console → Setup → API access
PLAY_STORE_JSON_KEY=/Users/nikita/.fastlane/play-store-key.json
