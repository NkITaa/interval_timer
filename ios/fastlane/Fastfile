default_platform(:ios)

platform :ios do
  # ──────────────────────────────────────────────
  # Setup & helpers
  # ──────────────────────────────────────────────

  before_all do
    setup_ci if ENV["CI"]
  end

  def api_key
    app_store_connect_api_key(
      key_id: "FC74HC6DF7",
      issuer_id: "6f4a1b6e-b779-48b3-8a4f-9402f6ef2f86",
      key_filepath: File.expand_path("~/.appstoreconnect/AuthKey_FC74HC6DF7.p8")
    )
  end

  desc "Install dependencies (Flutter pub get + CocoaPods)"
  lane :setup do
    Dir.chdir("../..") do
      sh("flutter pub get")
    end
  end

  # ──────────────────────────────────────────────
  # Build
  # ──────────────────────────────────────────────

  desc "Build debug (no codesign)"
  lane :build_debug do
    setup
    Dir.chdir("../..") do
      sh("flutter build ios --debug --no-codesign")
    end
  end

  desc "Build release IPA"
  lane :build_release do
    setup

    Dir.chdir("../..") do
      sh("flutter build ios --release --no-codesign")
    end

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "interval_timer.ipa",
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: "G5X499Q88J"
      }
    )
  end

  # ──────────────────────────────────────────────
  # Test
  # ──────────────────────────────────────────────

  desc "Run Flutter tests"
  lane :test do
    Dir.chdir("../..") do
      sh("flutter test")
    end
  end

  desc "Run Flutter analyze"
  lane :lint do
    Dir.chdir("../..") do
      sh("flutter analyze")
    end
  end

  # ──────────────────────────────────────────────
  # Deploy
  # ──────────────────────────────────────────────

  desc "Deploy to TestFlight"
  lane :beta do
    build_release

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Deploy to App Store"
  lane :release do
    build_release

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end

  # ──────────────────────────────────────────────
  # Utility
  # ──────────────────────────────────────────────

  desc "Bump build number in pubspec.yaml (uses latest TestFlight build + 1)"
  lane :bump_build do
    latest = latest_testflight_build_number(
      api_key: api_key,
      initial_build_number: 0
    )
    new_build = latest + 1

    pubspec = File.expand_path("../../pubspec.yaml")
    content = File.read(pubspec)
    content.gsub!(/^(version:\s*\d+\.\d+\.\d+\+)\d+/, "\\1#{new_build}")
    File.write(pubspec, content)

    UI.success("Build number bumped to #{new_build} in pubspec.yaml")
  end

  # ──────────────────────────────────────────────
  # Error handling
  # ──────────────────────────────────────────────

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end
end
